APP_NAME=GT Integrated Management System
APP_SUBTITLE=Gestão de Terminais, SA
APP_SHORT_NAME=GTIMS
APP_VERSION=3.0.0
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
RESET_STOCK_SECURITY_CODE=replace-with-a-private-reset-code
INITIAL_SUPERADMIN_PASSWORD=replace-with-a-strong-initial-password

# Production database connection. Required when ENVIRONMENT=production.
# DATABASE_URL=postgresql+psycopg://stock_user:strong_password@db-host:5432/stock_manager

# Local SQLite example for development only:
# ENVIRONMENT=development
# DATABASE_URL=sqlite:///C:/Users/Victus/OneDrive/Projects/GT-Stock-Manager/stock_manager.db

UPLOADS_DIR=/data/uploads
OUTPUTS_DIR=/data/outputs
DOCUMENTS_DIR=/data/uploads/stock_documents
EMAIL_OUTBOX_DIR=/data/outputs/email_outbox
LOGO_PATH=/app/app/static/img/logo-gt.png

SESSION_COOKIE_SECURE=true

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=stock@gtsa.local

# One-way sync. Use SYNC_MODE=primary locally and SYNC_MODE=mirror on Render.
SYNC_MODE=off
SYNC_AUTO_PUSH=false
SYNC_TARGET_URL=
SYNC_TOKEN=
SYNC_INTERVAL_SECONDS=300
MIRROR_READ_ONLY=true
