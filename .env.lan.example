APP_NAME=GT Integrated Management System
APP_SUBTITLE=Gestao de Terminais, SA
APP_SHORT_NAME=GTIMS
APP_VERSION=3.0.0

# Porta acessivel na rede local: http://IP_DO_SERVIDOR:8000
GTIMS_PORT=8000

# Base de dados local no computador-servidor
POSTGRES_DB=stock_manager
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=trocar-por-uma-senha-forte-da-base

# Segredos da aplicacao
SECRET_KEY=trocar-por-uma-chave-longa-e-aleatoria
RESET_STOCK_SECURITY_CODE=trocar-por-codigo-privado-de-reset
INITIAL_SUPERADMIN_PASSWORD=trocar-por-senha-inicial-forte

# Idioma padrao
DEFAULT_LANGUAGE=pt

# E-mail real, opcional. Sem SMTP, o sistema guarda mensagens no outbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=stock@gtsa.local

# WhatsApp real, opcional. Sem webhook, o sistema guarda mensagens no outbox.
WHATSAPP_WEBHOOK_URL=
WHATSAPP_SENDER=+258844231830

# Sincronizacao local principal -> Render mirror.
SYNC_MODE=off
SYNC_AUTO_PUSH=false
SYNC_TARGET_URL=
SYNC_TOKEN=
SYNC_INTERVAL_SECONDS=300
MIRROR_READ_ONLY=true
